{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: RP2040 (Pico/Pico W/Zero/Plus)",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceFolder}/.build/${workspaceFolderBasename}.ino.elf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "serverpath": "${config:cortex-debug.openocdPath}",
            "gdbPath": "${config:cortex-debug.gdbPath}",
            "device": "RP2040",
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/rp2040.cfg"
            ],
            "searchDir": [
                "${config:cortex-debug.openocdScriptsPath}"
            ],
            "svdFile": "${config:cortex-debug.svdFileRP2040}",
            "openOCDLaunchCommands": [
                "adapter speed 5000"
            ],
            "runToEntryPoint": "main",
            "postRestartCommands": [
                "break main",
                "continue"
            ],
            "preLaunchTask": "Project: Build (Debug)",
            "showDevDebugOutput": "parsed",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            }
        },
        {
            "name": "Debug: RP2350 (Pico 2/Pico 2W)",
