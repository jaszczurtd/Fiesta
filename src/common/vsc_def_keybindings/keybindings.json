// =====================================================================
// Arduino keyboard shortcuts for VS Code
//
//
// Installation:
//   Ctrl+K Ctrl+S  -> open keyboard shortcuts editor
//   Click the {} icon (top-right) -> open keybindings.json
//   Paste entries below into the [] array.
// =====================================================================
[
    {
        "key": "ctrl+shift+1",
        "command": "workbench.action.tasks.runTask",
        "args": "Project: Build",
        "when": "resourceExtname == .ino || editorLangId == cpp || editorLangId == c"
    },
    {
        "key": "ctrl+shift+2",
        "command": "workbench.action.tasks.runTask",
        "args": "Project: Upload",
        "when": "resourceExtname == .ino || editorLangId == cpp || editorLangId == c"
    },
    {
        "key": "ctrl+shift+3",
        "command": "workbench.action.tasks.runTask",
        "args": "Project: Monitor (persistent)",
        "when": "resourceExtname == .ino || editorLangId == cpp || editorLangId == c"
    },
    {
        "key": "ctrl+shift+4",
        "command": "workbench.action.tasks.runTask",
        "args": "Project: Upload (UF2 / BOOTSEL)",
        "when": "resourceExtname == .ino || editorLangId == cpp || editorLangId == c"
    },
    {
        "key": "ctrl+shift+5",
        "command": "workbench.action.tasks.runTask",
        "args": "Project: Monitor (Debug Probe)",
        "when": "resourceExtname == .ino || editorLangId == cpp || editorLangId == c"
    },
    {
        "key": "ctrl+shift+6",
        "command": "workbench.action.tasks.runTask",
        "args": "Project: Refresh IntelliSense",
        "when": "resourceExtname == .ino || editorLangId == cpp || editorLangId == c"
    },
    {
        "key": "ctrl+shift+7",
        "command": "workbench.action.tasks.runTask",
        "args": "Project: Clean",
        "when": "resourceExtname == .ino || editorLangId == cpp || editorLangId == c"
    },
    {
        "key": "ctrl+shift+8",
        "command": "workbench.action.tasks.runTask",
        "args": "Project: List ports",
        "when": "resourceExtname == .ino || editorLangId == cpp || editorLangId == c"
    },
    {
        "key": "ctrl+shift+9",
        "command": "workbench.action.tasks.runTask",
        "args": "Project: Change port",
        "when": "resourceExtname == .ino || editorLangId == cpp || editorLangId == c"
    },
    {
        "key": "ctrl+shift+0",
        "command": "workbench.action.tasks.runTask",
        "args": "Project: Install library",
        "when": "resourceExtname == .ino || editorLangId == cpp || editorLangId == c"
    },
    {
        "key": "ctrl+shift+y",
        "command": "workbench.action.tasks.runTask",
        "args": "Quality: Cppcheck baseline",
        "when": "resourceExtname == .ino || editorLangId == cpp || editorLangId == c"
    },
    {
        "key": "ctrl+shift+alt+1",
        "command": "workbench.action.tasks.runTask",
        "args": "Project: Select board (GUI)",
        "when": "resourceExtname == .ino || editorLangId == cpp || editorLangId == c"
    },
    {
        "key": "ctrl+shift+alt+2",
        "command": "workbench.action.tasks.runTask",
        "args": "Project: Select board (interactive)",
        "when": "resourceExtname == .ino || editorLangId == cpp || editorLangId == c"
    }
]
