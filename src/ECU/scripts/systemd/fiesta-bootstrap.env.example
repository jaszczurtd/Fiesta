# =============================================================================
# Fiesta daily bootstrap — configuration (example)
#
# Copy to ~/.config/fiesta-bootstrap.env on the Pi and chmod 600.
# The systemd unit loads this file via EnvironmentFile=.
# =============================================================================

# Location + branch -----------------------------------------------------------
FIESTA_DIR=%h/Documents/Fiesta
FIESTA_REPO_URL=https://github.com/jaszczurtd/Fiesta.git
BRANCH=main

# Optional log directory (default: $HOME/.cache/fiesta-bootstrap).
# FIESTA_LOG_DIR=%h/.cache/fiesta-bootstrap

# SMTP --------------------------------------------------------------------
# Port 465 = implicit TLS (SMTPS). Any other port uses STARTTLS.
# For Gmail use an app password, not your account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.bot.account@gmail.com
SMTP_PASS=change-me-app-password

# From / To ---------------------------------------------------------------
MAIL_FROM=your.bot.account@gmail.com
MAIL_TO=you@example.com
